generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  telegramId  String       @unique @map("telegram_id")
  name        String
  surname     String
  phone       String       @unique
  region      String
  district    String
  createdAt   DateTime     @default(now())
  tests       Test[]
  testResults TestResult[]
}

model Test {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  testCode    Int          @unique @default(0) // Auto-incrementing test code
  title       String
  description String?
  telegramId  String       @map("author_id")
  answerKeys  Json // { "1": "A", "2": "B", ..., "36.1": "A", "36.2": "B" }
  createdAt   DateTime     @default(now())
  author      User         @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)
  testResults TestResult[]

  @@index([telegramId])
}

model TestResult {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  telegramId  String
  testCode    Int
  answers     Json // { "1": "A", "2": "B", ... }
  score       Int      @default(0) // To'g'ri javoblar soni
  total       Int      @default(45) // Jami savollar
  rawScore    Float    @default(0) // Xom ball (0-88)
  scaledScore Float    @default(0) // Standart ball (0-100)
  percentage  Float    @default(0) // Foiz
  grade       String? // A+, A, B+, B, C+, C, F
  isCertified Boolean  @default(false) // Sertifikat oldimi
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)
  test        Test     @relation(fields: [testCode], references: [testCode], onDelete: Cascade)

  @@index([telegramId, testCode])
}
