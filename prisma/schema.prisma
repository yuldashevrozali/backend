generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  telegramId   String   @unique @map("telegram_id")
  name         String
  surname      String
  phone        String   @unique
  region       String
  district     String
  createdAt    DateTime @default(now())
  tests        Test[]
  testResults  TestResult[]
}

model Test {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  testCode     Int      @unique @default(0)
  title        String
  description  String?
  telegramId   String   @map("author_id")
  status       String   @default("active")  // active, finished
  createdAt    DateTime @default(now())
  questions    Question[]
  author       User     @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)
  testResults  TestResult[]

  @@index([telegramId])
}

model Question {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  testCode      Int     @map("test_code")
  num           Int     // 1-45
  part          String? // null, "1", "2" for 36-45
  correctAnswer String
  difficulty    Float   @default(0)  // RASCH difficulty parameter (-3 to +3)
  test          Test    @relation(fields: [testCode], references: [testCode], onDelete: Cascade)
}

model TestResult {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  telegramId String
  testCode  Int
  theta     Float    @default(0)          // RASCH ability parameter
  answers   Json     @default("{}")       // { "1": "A", "36.1": "5", ... }
  score     Int      @default(0)          // correct count
  total     Int      @default(45)
  rawScore  Float    @default(0)
  scaledScore Float  @default(0)
  percentage Float   @default(0)
  grade     String?
  isCertified Boolean @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)
  test      Test     @relation(fields: [testCode], references: [testCode], onDelete: Cascade)

  @@index([telegramId, testCode])
}
